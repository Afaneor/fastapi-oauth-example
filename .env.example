POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

APP_PORT=8000
WORKERS=8

# Яндекс OAuth2 настройки
# Получи на https://oauth.yandex.ru/
YANDEX_CLIENT_ID=your_client_id_here
YANDEX_CLIENT_SECRET=your_client_secret_here

# JWT настройки
# Сгенерируй надежный ключ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_here

# Redirect URI (должен совпадать с настройками в Яндекс.OAuth)
REDIRECT_URI=http://localhost:8000/auth/callback
YANDEX_OAUTH_URL=https://oauth.yandex.ru/authorize
YANDEX_TOKEN_URL=https://oauth.yandex.ru/token
YANDEX_API_BASE_URL=https://login.yandex.ru/info
